# ─── Database (Supabase Postgres) ───
# Pooled connection for the app (PgBouncer / Supabase pooler, port 6543).
# Once RLS is active (see docs/RLS.md), this should be the NON-superuser
# `app_user` role so the FORCEd policies constrain the runtime.
DATABASE_URL="postgresql://app_user:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true"
# Direct connection as the privileged `postgres` role — migrations, seeds, and
# applying prisma/roles.sql + prisma/rls.sql (this role has BYPASSRLS).
DIRECT_URL="postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres"
# Optional: explicit app_user URL for `npm run db:rls:check`. Defaults to nothing;
# the check needs both this (restricted) and DIRECT_URL (privileged) set.
APP_DATABASE_URL="postgresql://app_user:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true"

# ─── Supabase Auth ───
NEXT_PUBLIC_SUPABASE_URL="https://<ref>.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="<anon-key>"
SUPABASE_SERVICE_ROLE_KEY="<service-role-key>"   # server-only, never expose

# ─── Platform owner seed (npm run db:seed:owner) ───
# Creates/links the PlatformUser. Either give OWNER_EMAIL + OWNER_PASSWORD with a
# real SERVICE_ROLE_KEY (auto-creates the Supabase auth user), or OWNER_EMAIL +
# OWNER_USER_ID if you already created the auth user in the Supabase dashboard.
OWNER_EMAIL="owner@yourplatform.app"
OWNER_PASSWORD="<strong-password>"
# OWNER_USER_ID="<supabase-auth-user-uuid>"

# ─── Platform routing ───
NEXT_PUBLIC_ROOT_DOMAIN="yourplatform.app"       # use "localhost:3000" pattern in dev
# Super Admin lives at admin.<root>. If you don't have that subdomain yet (e.g.
# on a bare *.vercel.app URL), set this to the deployment host to serve the admin
# at its root. *.vercel.app hosts already do this automatically.
# NEXT_PUBLIC_ADMIN_HOST="myapp.vercel.app"

# ─── ImageKit ───
NEXT_PUBLIC_IMAGEKIT_PUBLIC_KEY="<public-key>"
NEXT_PUBLIC_IMAGEKIT_URL_ENDPOINT="https://ik.imagekit.io/<id>"
IMAGEKIT_PRIVATE_KEY="<private-key>"             # server-only

# ─── Vercel (custom domain provisioning during onboarding) ───
VERCEL_API_TOKEN="<token>"
VERCEL_PROJECT_ID="<project-id>"
VERCEL_TEAM_ID="<team-id>"

# ─── Secret encryption for Integration.credentials (32-byte hex) ───
ENCRYPTION_KEY="<openssl rand -hex 32>"
